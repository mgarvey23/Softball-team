rules_version = '2';

// The whole team shares a single document per team at teams/{teamId}. Players
// sign in anonymously (no login screen), so require an authenticated request
// but do not tie writes to a specific user -- everyone on the team collaborates
// on the same document.
//
// This is a sensible starting point for a small private rec team. If you want
// tighter control later (e.g. only named members can write), we can add a
// members list and check it here.
//
// Paste these rules into Firebase console -> Firestore Database -> Rules.
service cloud.firestore {
  match /databases/{database}/documents {
    // Covers the team document at teams/{teamId} AND everything under it,
    // including the teams/{teamId}/backups subcollection of auto-saved
    // snapshots. The {document=**} wildcard is what extends access to the
    // subcollection (rules do not cascade to subcollections otherwise).
    match /teams/{teamId}/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
