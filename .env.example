# Firebase web app config. Copy this file to ".env" and fill in the values from
# your Firebase project (Project settings -> Your apps -> Web app -> SDK config).
# These are safe to expose in a client app; access is controlled by Firestore
# security rules and the authorized-domains list. Do NOT commit your real .env.
#
# When these are set, the whole team shares one live database (players sign in
# anonymously behind the scenes -- no login screen). When they are absent, the
# app runs in on-device local mode so you can still try it out.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: which shared team document to use. Lets you run multiple teams from
# one Firebase project. Defaults to "main".
VITE_TEAM_ID=main
